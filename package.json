{
  "name": "marine-navigator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "postbuild": "node scripts/copy-static.js",
    "preview": "vite preview --host 0.0.0.0",
    "proxy": "node server/proxy-server.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "check": "node --check app.js && node --check service-worker.js && node --check server/proxy-server.js",
    "cap:init": "cap init \"Marine Navigator\" \"com.lovlaus.marinenavigator\" --web-dir=dist",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@playwright/test": "^1.57.0",
    "vite": "^7.2.0"
  }
}
